# ── Backend Environment Variables ──────────────────────────────
# Set these in Vercel → Project Settings → Environment Variables

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (REQUIRED for Vercel - localhost won't work)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/behold_aspire?retryWrites=true&w=majority

# JWT Secrets (change these to long random strings in production!)
JWT_SECRET=your_jwt_secret_here_change_this
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_this

# Default admin credentials (seeded on first run)
DEFAULT_ADMIN_EMAIL=admin@behold.com
DEFAULT_ADMIN_PASSWORD=Admin@123

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-project-name.vercel.app
